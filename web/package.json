{
  "name": "@exeligmos/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api:generate": "openapi-typescript ../sync-server/openapi/openapi.yaml -o packages/api-client/src/schema.ts",
    "catalog:generate": "node scripts/generate-domain-catalog.mjs",
    "solar:generate": "node scripts/generate-solar-temporal-data.mjs",
    "solar:check": "node scripts/generate-solar-temporal-data.mjs --check",
    "domain:validate": "npm --prefix ../domain-spec test",
    "build": "npm run catalog:generate && npm run solar:generate && npm run api:generate && react-router build",
    "dev": "react-router dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "react-router-serve ./build/server/index.js",
    "predev": "npm run catalog:generate && npm run solar:generate && npm run api:generate",
    "test": "npm run catalog:generate && npm run solar:generate && vitest run",
    "test:watch": "npm run solar:generate && vitest",
    "typecheck": "npm run catalog:generate && npm run solar:generate && npm run api:generate && react-router typegen && tsc --noEmit",
    "check": "npm run domain:validate && npm run solar:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@exeligmos/api-client": "*",
    "@exeligmos/domain-catalog": "*",
    "@exeligmos/glyph-core": "*",
    "@exeligmos/temporal-core": "*",
    "@exeligmos/ui": "*",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.2.0",
    "isbot": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "8.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
