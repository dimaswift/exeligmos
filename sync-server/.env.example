NODE_ENV=development
HOST=0.0.0.0
PORT=8788
LOG_LEVEL=info
# Exact number of reverse-proxy hops between clients and this process. Keep 0
# for direct traffic; do not blindly trust arbitrary X-Forwarded-For headers.
TRUST_PROXY_HOPS=0
SHUTDOWN_TIMEOUT_MS=10000

POSTGRES_DB=exeligmos
POSTGRES_USER=exeligmos
POSTGRES_PASSWORD=replace_with_a_long_url_safe_random_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://exeligmos:replace_with_a_long_url_safe_random_password@localhost:5432/exeligmos
MIGRATIONS_DIR=db/migrations

DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_READINESS_TIMEOUT_MS=2000
DB_STATEMENT_TIMEOUT_MS=15000
DB_LOCK_TIMEOUT_MS=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000

# Persistent v2 media bytes. Keep this outside the read-only legacy data/
# hierarchy used by import:legacy.
MEDIA_STORAGE_ROOT=var/media
MEDIA_MAX_BYTE_LENGTH=5368709120
MEDIA_UPLOAD_TTL_SECONDS=86400

AUTH_REGISTRATION_MODE=open
# Required only when AUTH_REGISTRATION_MODE=invite.
# AUTH_REGISTRATION_INVITE_CODE=replace_with_a_private_invite_code
AUTH_JWT_ISSUER=exeligmos-sync-server
AUTH_JWT_AUDIENCE=exeligmos-clients
AUTH_JWT_KEY_ID=primary
# Generate once and store securely:
# openssl genpkey -algorithm ED25519 -outform DER | base64 | tr -d '\n'
AUTH_JWT_PRIVATE_KEY_BASE64=replace_with_base64_pkcs8_ed25519_private_key
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_ARGON2_MAX_CONCURRENCY=2
