{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:exeligmos:domain-conformance-vectors:schema:1",
  "title": "Exeligmos domain conformance vectors",
  "type": "object",
  "required": ["$schema", "schemaVersion", "catalogVersion", "floatTolerance", "vectors"],
  "properties": {
    "$schema": {
      "const": "./vectors.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "catalogVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "floatTolerance": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/vector"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "vector": {
      "type": "object",
      "required": ["id", "source", "operation", "input", "expected"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "source": {
          "enum": ["swift-test", "swift-implementation", "catalog-policy"]
        },
        "operation": {
          "enum": [
            "clampPresentationDepth",
            "canonicalOctalAddress",
            "rarityOctalAddress",
            "normalizeGlyphOctal",
            "classifyRarity",
            "rarityDescriptor",
            "pulseDuration",
            "clockReading",
            "glyphSocketDigitIndices",
            "glyphFrameBounds",
            "eventTypeResolution"
          ]
        },
        "input": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
